#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

cd "$REPO_ROOT"
export GLYPH_RUNTIME_ROOT="$REPO_ROOT"
export GLYPH_VOICE_LOG_PATH="${GLYPH_VOICE_LOG_PATH:-$REPO_ROOT/runtime/glyph_voice.log}"
export PYTHONPATH="$REPO_ROOT/python_engine${PYTHONPATH:+:$PYTHONPATH}"

exec python3 -m glyph_voice "$@"
