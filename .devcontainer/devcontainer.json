{
  "name": "Glyph",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && cd workflows-demo && npm install",
  "forwardPorts": [8000, 8787],
  "portsAttributes": {
    "8000": { "label": "Glyph API", "onAutoForward": "notify" },
    "8787": { "label": "Glyph Voice", "onAutoForward": "notify" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
